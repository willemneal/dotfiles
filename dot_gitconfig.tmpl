{{- if eq .chezmoi.os "darwin" -}}
[user]
  name = {{ .name | quote }}
  email = {{ .email | quote }}
{{- if index . "signing_key" }}
  signingkey = {{ .signing_key | quote }}
{{- end }}

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[core]
  editor = nvim
  pager = delta

[diff]
  colorMoved = default

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  light = false
  side-by-side = true

[merge]
  conflictstyle = zdiff3

[alias]
  s = status -sb
  co = checkout
  br = branch
  ci = commit
  lg = log --graph --abbrev-commit --pretty=format:'%C(auto)%h%d %s %C(dim)(%cr) <%an>'
{{ if index . "signing_key" }}
[commit]
  gpgsign = true

[tag]
  gpgsign = true

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
  allowedSignersFile = "~/.ssh/allowed_signers"
{{ end -}}
{{ end -}}
