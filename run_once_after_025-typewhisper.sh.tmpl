{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

{{ template "brew-shellenv.sh" . -}}

# TypeWhisper is distributed only as a GitHub-released DMG (not on Homebrew
# or MAS). Fetch the latest *app* release, compare with the installed
# CFBundleShortVersionString, and only download + install when out of date.
# Updates beyond this point are handled by TypeWhisper's in-app updater.
#
# All failures here exit 0: TypeWhisper is non-essential and a network blip,
# release-asset oddity, or DMG hiccup must not abort the rest of the apply
# (chezmoi treats a non-zero run_once_after as fatal for the whole run).
APP="/Applications/TypeWhisper.app"
REPO="TypeWhisper/typewhisper-mac"
# /releases/latest returns whichever non-prerelease+non-draft is newest by
# created_at. The repo also publishes plugin releases (`plugin-foo-v…`,
# .zip-only) under the same repo, which sort ahead of app releases by
# date. Pull the full list and filter to releases that actually ship a
# .dmg — that's the strongest "this is an app release" signal.
API="https://api.github.com/repos/${REPO}/releases?per_page=100"

if ! command -v jq >/dev/null 2>&1; then
  echo "[typewhisper] jq missing — skipping (run brew bundle first)." >&2
  exit 0
fi

release_json="$(curl -fsSL "$API")" || {
  echo "[typewhisper] could not reach GitHub API; skipping." >&2
  exit 0
}

release="$(printf '%s' "$release_json" | jq -c '
  [ .[] | select(.prerelease == false and .draft == false)
        | select([.assets[]? | .name | endswith(".dmg")] | any) ]
  | first
')"

if [ -z "$release" ] || [ "$release" = "null" ]; then
  echo "[typewhisper] no stable release with a .dmg asset in last 100 releases; skipping." >&2
  exit 0
fi

latest_tag="$(printf '%s' "$release" | jq -r '.tag_name')"
latest_version="${latest_tag#v}"

if [ -d "$APP" ]; then
  installed_version="$(/usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' \
    "$APP/Contents/Info.plist" 2>/dev/null || echo '')"
  if [ "$installed_version" = "$latest_version" ]; then
    echo "[typewhisper] $latest_version already installed."
    exit 0
  fi
fi

dmg_url="$(printf '%s' "$release" \
  | jq -r '.assets[] | select(.name | endswith(".dmg")) | .browser_download_url' \
  | head -n1)"

if [ -z "$dmg_url" ]; then
  echo "[typewhisper] release $latest_tag advertised a .dmg but extraction failed; skipping." >&2
  exit 0
fi

tmp="$(mktemp -d)"
mountpoint=""
cleanup() {
  if [ -n "$mountpoint" ] && [ -d "$mountpoint" ]; then
    hdiutil detach "$mountpoint" -quiet 2>/dev/null || true
  fi
  rm -rf "$tmp"
}
trap cleanup EXIT

dmg="$tmp/TypeWhisper.dmg"
echo "[typewhisper] downloading $latest_tag"
if ! curl -fsSL "$dmg_url" -o "$dmg"; then
  echo "[typewhisper] download failed; skipping." >&2
  exit 0
fi

mountpoint="$(hdiutil attach "$dmg" -nobrowse -quiet \
  | awk -F'\t' '/\/Volumes\// { print $NF; exit }')"
if [ -z "$mountpoint" ]; then
  echo "[typewhisper] failed to mount DMG; skipping." >&2
  exit 0
fi

src="$(find "$mountpoint" -maxdepth 2 -name 'TypeWhisper.app' -print -quit)"
if [ -z "$src" ]; then
  echo "[typewhisper] TypeWhisper.app not found in DMG; skipping." >&2
  exit 0
fi

[ -d "$APP" ] && rm -rf "$APP"
ditto "$src" "$APP"
xattr -dr com.apple.quarantine "$APP" 2>/dev/null || true

echo "[typewhisper] installed $latest_version"
{{ end -}}
