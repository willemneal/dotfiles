{{- if and (eq .chezmoi.os "darwin") (has .chezmoi.hostname .hosts.ai_machines) -}}
#!/usr/bin/env bash
# Persist iogpu.wired_limit_mb across reboots so MLX has GPU headroom for
# 70B+ models. macOS resets the limit to ~75% of physical at every boot;
# this LaunchDaemon raises it back to ~95% (rounded down to a MiB boundary).
# Requires sudo on first install — same UX as the Homebrew bootstrap.
set -euo pipefail

PLIST=/Library/LaunchDaemons/local.iogpu.wired-limit.plist

# `iogpu` is only present on hosts with Apple Silicon GPUs exposed via the
# native macOS GPU stack. Tart/Virtualization.framework guests don't see it,
# nor do Intel Macs. Skip cleanly in those cases.
if ! sysctl -n iogpu.wired_limit_mb >/dev/null 2>&1; then
  echo "iogpu sysctl not available on this host; skipping wired-limit setup" >&2
  exit 0
fi

phys_mb=$(($(sysctl -n hw.memsize) / 1024 / 1024))
target=$(( (phys_mb * 95 / 100) / 1024 * 1024 ))

if [ -f "$PLIST" ] && grep -q "iogpu.wired_limit_mb=${target}" "$PLIST"; then
  echo "iogpu plist already current (target=${target} MiB of ${phys_mb} MiB physical)"
  exit 0
fi

tmp=$(mktemp)
cat > "$tmp" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>local.iogpu.wired-limit</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/sbin/sysctl</string>
        <string>iogpu.wired_limit_mb=${target}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
EOF

sudo install -m 0644 -o root -g wheel "$tmp" "$PLIST"
rm -f "$tmp"

sudo launchctl bootout system "$PLIST" 2>/dev/null || true
sudo launchctl bootstrap system "$PLIST"
sudo sysctl "iogpu.wired_limit_mb=${target}"

echo "iogpu.wired_limit_mb persisted at ${target} MiB (${phys_mb} MiB physical)"
{{ end -}}
