{{- if eq .chezmoi.os "darwin" -}}
# To pin a fast-moving package, replace `brew "uv"` with `brew "uv@<version>"`
# once a tap exists, or vendor via `brew extract`. Pin only on regression —
# default is unpinned.

# CLI essentials
brew "git"
brew "gh"
brew "jq"
brew "yq"
brew "fzf"
brew "direnv"
brew "zoxide"
brew "starship"
brew "neovim"
brew "tmux"

# Rust-written CLI replacements
brew "ripgrep"
brew "fd"
brew "bat"
brew "eza"

# Rust CLI extras
brew "git-delta"
brew "dust"
brew "tokei"
brew "hyperfine"
brew "bottom"
brew "gitui"
brew "just"

# Terminal stack
cask "alacritty"
brew "zellij"

# Dev
brew "uv"
brew "mise"
brew "node"

# Rust toolchain — run `rustup default stable` once after install.
# cargo-binstall is here for crates brew doesn't ship; brew remains the
# default for the Rust CLIs above.
brew "rustup"
brew "cargo-binstall"
{{ if has .chezmoi.hostname .hosts.ai_machines }}
# AI (host-gated)
brew "llama.cpp"
brew "ollama"
brew "asitop"      # Apple Silicon GPU/memory monitor — leaner than btm for inference work
cask "lm-studio"
{{ end }}
# Productivity
cask "raycast"
cask "rectangle"
cask "1password"
cask "1password-cli"
cask "tailscale-app"
{{ end -}}
