{{- if eq .chezmoi.os "darwin" -}}
# To pin a fast-moving package, replace `brew "uv"` with `brew "uv@<version>"`
# once a tap exists, or vendor via `brew extract`. Pin only on regression —
# default is unpinned.

# Third-party taps
tap "nikitabobko/tap"   # aerospace
tap "xykong/tap"        # flux-markdown (QuickLook)

# CLI essentials
brew "git"
brew "gh"
brew "jq"
brew "yq"
brew "fzf"
brew "direnv"
brew "zoxide"
brew "starship"
brew "neovim"
brew "tmux"
brew "repomix"  # bundle a repo into a single AI-friendly file (Claude Code companion)
brew "mas"      # Mac App Store CLI — drives `mas` lines below

# Zsh enhancements
brew "zsh-autosuggestions"
brew "zsh-fast-syntax-highlighting"
brew "atuin"   # SQLite-backed shell history; see dot_config/atuin/config.toml

# Rust-written CLI replacements
brew "ripgrep"
brew "fd"
brew "bat"
brew "eza"

# Rust CLI extras
brew "git-delta"
brew "dust"
brew "tokei"
brew "hyperfine"
brew "bottom"
brew "gitui"
brew "just"

# Terminal stack
cask "alacritty"           # OpenGL terminal — primary; Cmd+Shift+P → SSH profile picker
cask "ghostty"             # Metal-native terminal — compare against alacritty
brew "zellij"

# Editors
cask "zed"                 # Metal-rendered code editor; quick alt to nvim for big files

# Dev
brew "uv"
brew "mise"
brew "node"

# Rust toolchain — run `rustup default stable` once after install.
# cargo-binstall is here for crates brew doesn't ship; brew remains the
# default for the Rust CLIs above.
brew "rustup"
brew "cargo-binstall"
{{ if has .chezmoi.hostname .hosts.ai_machines }}
# AI (host-gated)
brew "llama.cpp"
brew "ollama"
brew "whisper-cpp" # local speech-to-text; pairs with mlx for audio→LLM pipelines
brew "asitop"      # Apple Silicon GPU/memory monitor — leaner than btm for inference work
brew "mactop"      # Per-core CPU/GPU + thermal sensors; complements asitop
cask "lm-studio"           # GUI for local LLMs (gguf + MLX models)
{{ end }}
# Productivity
cask "raycast"             # Spotlight replacement — launcher, snippets, clipboard, extensions
cask "nikitabobko/tap/aerospace"  # i3-style tiling (replaces rectangle)
cask "karabiner-elements"  # Caps Lock → Esc on tap / Hyper on hold
cask "linearmouse"         # mouse customisation: per-device speed/scroll/buttons
cask "1password"           # password manager + SSH agent (used for git commit signing)
cask "1password-cli"       # `op` — read by hf-login / gh-login / op-creds-bootstrap
cask "tailscale-app"       # mesh VPN — `tailscale-up` pulls auth key from 1Password
cask "claude"              # Anthropic desktop app — companion to Claude Code
cask "obsidian"            # local-first markdown PKM; vault is plain files
cask "appcleaner"          # clean uninstall — drag app, removes prefs/caches
cask "dockdoor"            # hover Dock icons → window previews (Alt-Tab-style peek)
cask "xykong/tap/flux-markdown"  # QuickLook plugin: rich markdown previews (math/code/mermaid)
# TypeWhisper (local speech-to-text) is not on Homebrew — installed by
# run_once_after_025-typewhisper.sh from GitHub releases.

# Communication
cask "slack"               # team chat
cask "discord"             # voice/text chat — gaming + dev communities
cask "zoom"                # video meetings
cask "signal"              # E2E encrypted messaging
cask "telegram"            # messaging

# Media
cask "vlc"                 # play anything; no codec hunt
cask "iina"                # native Mac media player (Metal-rendered)
cask "obs"                 # streaming/recording — VideoToolbox HW encode
cask "handbrake"           # video transcoding
cask "audacity"            # audio editor

# Creative / GPU
cask "blender"             # 3D — Cycles has a Metal backend
cask "godot"               # game engine, native ARM64, ~100 MB
cask "epic-games"          # Epic launcher → installs Unreal Engine
cask "draw-things"         # local Stable Diffusion / Flux on MLX
cask "upscayl"             # image upscaler (Real-ESRGAN, Metal)
# Not on Homebrew (registration-walled): DaVinci Resolve
#   https://www.blackmagicdesign.com/products/davinciresolve

# Games / Windows compat
cask "steam"               # game launcher
cask "nvidia-geforce-now"  # cloud gaming
cask "crossover"           # Windows app translation via GPTK + Wine

# Security / wallets
cask "yubico-authenticator" # YubiKey OATH/TOTP
cask "ledger-live"         # hardware wallet
cask "protonvpn"           # VPN client

# Mac App Store (requires Apple ID signed into App Store; app must be
# previously "obtained" on this Apple ID for `mas install` to succeed).
mas "Flighty", id: 1358823008
# Meeter (Nuvio Labs) was pulled from MAS — get it from https://meeter.app
# Substitute: `mas "MeetingBar", id: 1532419400`

# Containers
# macOS 26+ ships native OCI container support via /usr/bin/container
# (Apple's Containerization framework). For occasional `container run`
# that's enough — no install needed. Uncomment the cask below if you
# need any of: docker-compose, multi-arch (Rosetta-translated x86
# images), Kubernetes, drop-in `docker` CLI compatibility, or a GUI.
# cask "orbstack"
{{ end -}}
