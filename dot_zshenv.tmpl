{{- if eq .chezmoi.os "darwin" -}}
{{ template "brew-shellenv.sh" . -}}

export PATH="$HOME/.local/bin:$PATH"

export EDITOR=nvim
export VISUAL="$EDITOR"

export HF_HUB_ENABLE_HF_TRANSFER=1
export MODELS_DIR="$HOME/Models"
# export HF_HOME="/Volumes/External/hf"

# Lazy HF_TOKEN via 1Password — call `hf-login` (or `op signin` first if needed).
# Adjust the op:// reference if your vault layout differs.
hf-login() {
  command -v op >/dev/null || { print -u2 "op (1Password CLI) not installed"; return 1; }
  HF_TOKEN=$(op read "op://Personal/HuggingFace/credential") || return $?
  export HF_TOKEN
}

# Bring tailscale up using a reusable auth key from 1Password.
# Pass extra flags through, e.g. `tailscale-up --accept-routes`.
tailscale-up() {
  command -v tailscale >/dev/null || { print -u2 "tailscale not installed"; return 1; }
  command -v op        >/dev/null || { print -u2 "op (1Password CLI) not installed"; return 1; }
  if tailscale status >/dev/null 2>&1; then
    print "tailscale already up"
    return 0
  fi
  local key
  key=$(op read "op://Personal/Tailscale/credential") || return $?
  TS_AUTHKEY="$key" tailscale up "$@"
}

# Authenticate the GitHub CLI by exporting GH_TOKEN from 1Password.
# `gh` reads GH_TOKEN automatically — no `gh auth login` step needed.
gh-login() {
  command -v op >/dev/null || { print -u2 "op (1Password CLI) not installed"; return 1; }
  GH_TOKEN=$(op read "op://Personal/GitHub CLI/credential") || return $?
  export GH_TOKEN
}

# Load OpenRouter API key from 1Password. OpenRouter is an
# OpenAI-compatible gateway to every major model (Claude, GPT, Gemini,
# Groq-hosted Llama, etc.) — one key replaces per-provider keys.
openrouter-login() {
  command -v op >/dev/null || { print -u2 "op (1Password CLI) not installed"; return 1; }
  OPENROUTER_API_KEY=$(op read "op://Personal/OpenRouter/credential") || return $?
  export OPENROUTER_API_KEY
}

# Create an API Credential item in the Personal vault without exposing
# the secret in argv or shell history. The secret reaches op via stdin
# (kernel pipe — private to jq/op), never as a CLI flag.
op-cred() {
  command -v op >/dev/null || { print -u2 "op not installed"; return 1; }
  command -v jq >/dev/null || { print -u2 "jq not installed"; return 1; }
  [ $# -eq 1 ] || { print -u2 "usage: op-cred <item-title>"; return 2; }
  printf "Paste credential for %s (input hidden): " "$1" >&2
  IFS= read -rs; print
  [ -z "$REPLY" ] && { print -u2 "(empty — aborting)"; return 1; }
  print -nr -- "$REPLY" | jq -Rn --arg t "$1" '{
    title: $t,
    category: "API_CREDENTIAL",
    vault: { name: "Personal" },
    fields: [ { id: "credential", type: "CONCEALED", value: input } ]
  }' | op item create --template - >/dev/null \
    && print "✓ $1 created" || print -u2 "✗ $1 failed"
  unset REPLY
}

# Idempotent bootstrap of the credentials the dotfiles' *-login
# functions expect. Skips items that already exist; press Enter to
# skip an item you don't have yet.
op-creds-bootstrap() {
  command -v op >/dev/null || { print -u2 "op not installed"; return 1; }
  local needed=(
    "OpenRouter"
    "OpenRouter Provisioning"
    "GitHub CLI"
    "HuggingFace"
    "Tailscale"
  )
  for title in $needed; do
    if op item get "$title" --vault Personal >/dev/null 2>&1; then
      print "✓ $title (already exists)"
    else
      op-cred "$title" || true
    fi
  done
}

[ -f "$HOME/.zshenv.local" ] && . "$HOME/.zshenv.local"
{{ end -}}
