{{- if eq .chezmoi.os "darwin" -}}
{{ template "brew-shellenv.sh" . -}}

export PATH="$HOME/.local/bin:$PATH"

export EDITOR=nvim
export VISUAL="$EDITOR"

export HF_HUB_ENABLE_HF_TRANSFER=1
export MODELS_DIR="$HOME/Models"
# export HF_HOME="/Volumes/External/hf"

# Lazy HF_TOKEN via 1Password — call `hf-login` (or `op signin` first if needed).
# Adjust the op:// reference if your vault layout differs.
hf-login() {
  command -v op >/dev/null || { print -u2 "op (1Password CLI) not installed"; return 1; }
  HF_TOKEN=$(op read "op://Personal/HuggingFace/credential") || return $?
  export HF_TOKEN
}

# Bring tailscale up using a reusable auth key from 1Password.
# Pass extra flags through, e.g. `tailscale-up --accept-routes`.
tailscale-up() {
  command -v tailscale >/dev/null || { print -u2 "tailscale not installed"; return 1; }
  command -v op        >/dev/null || { print -u2 "op (1Password CLI) not installed"; return 1; }
  if tailscale status >/dev/null 2>&1; then
    print "tailscale already up"
    return 0
  fi
  local key
  key=$(op read "op://Personal/Tailscale/credential") || return $?
  TS_AUTHKEY="$key" tailscale up "$@"
}

# Authenticate the GitHub CLI by exporting GH_TOKEN from 1Password.
# `gh` reads GH_TOKEN automatically — no `gh auth login` step needed.
gh-login() {
  command -v op >/dev/null || { print -u2 "op (1Password CLI) not installed"; return 1; }
  GH_TOKEN=$(op read "op://Personal/GitHub CLI/credential") || return $?
  export GH_TOKEN
}

[ -f "$HOME/.zshenv.local" ] && . "$HOME/.zshenv.local"
{{ end -}}
