{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# Health check for the local AI dev environment.
# Status only — never gates. Always exits 0.
set -uo pipefail

issues=0
ok()   { printf "  \033[32m✓\033[0m %s\n" "$*"; }
warn() { printf "  \033[33m!\033[0m %s\n" "$*"; issues=$((issues+1)); }
miss() { printf "  \033[31m✗\033[0m %s\n" "$*"; issues=$((issues+1)); }
section() { printf "\n\033[1m%s\033[0m\n" "$*"; }

ver() {
  local label="$1" cmd="$2"; shift 2
  if command -v "$cmd" >/dev/null 2>&1; then
    ok "$label: $("$cmd" "$@" 2>&1 | head -n1)"
  else
    miss "$label: not installed"
  fi
}

PLAYGROUND="$HOME/ai/playground"
MODELS="${MODELS_DIR:-$HOME/Models}"
HF_CACHE="${HF_HOME:-$HOME/.cache/huggingface}"

section "Versions"
ver brew      brew      --version
ver uv        uv        --version
ver ollama    ollama    --version
ver llama-cli llama-cli --version

if [ -x "$PLAYGROUND/.venv/bin/python" ]; then
  ok "playground python: $("$PLAYGROUND/.venv/bin/python" --version 2>&1)"
  # Use `uv pip show` (uv's built-in resolver) — uv-managed venvs don't
  # include `pip`, so `uv run pip show` would silently fail.
  for pkg in mlx mlx-lm mlx-vlm; do
    if v=$(cd "$PLAYGROUND" && uv pip show "$pkg" 2>/dev/null | awk '/^Version:/ {print $2}'); [ -n "${v:-}" ]; then
      ok "$pkg: $v"
    else
      miss "$pkg: not installed in playground"
    fi
  done
else
  miss "playground venv missing — run \`chezmoi apply\` to bootstrap"
fi

section "Apps"
if [ -d "/Applications/LM Studio.app" ]; then
  ok "LM Studio: installed"
else
  miss "LM Studio: not installed (cask: lm-studio)"
fi

section "Services"
if command -v ollama >/dev/null 2>&1; then
  if ollama list >/dev/null 2>&1; then
    ok "ollama daemon: reachable ($(ollama list 2>/dev/null | tail -n +2 | wc -l | tr -d ' ') models)"
  else
    warn "ollama daemon: not running (\`ollama serve\` or open the app)"
  fi
fi
if [ -x "$PLAYGROUND/.venv/bin/hf" ]; then
  if user=$(cd "$PLAYGROUND" && uv run hf auth whoami 2>/dev/null | awk '/^user:/ {print $2; exit}') && [ -n "$user" ]; then
    ok "HF auth: $user"
  else
    warn "HF auth: not logged in (run \`hf-login\` or \`hf auth login\`)"
  fi
fi
if curl -sfI --max-time 3 https://huggingface.co >/dev/null 2>&1; then
  ok "huggingface.co: reachable"
else
  warn "huggingface.co: unreachable (network/DNS/firewall)"
fi

section "Disk"
ok "$HOME free: $(df -h "$HOME" | awk 'NR==2 {print $4}')"
if [ -d "$MODELS" ]; then
  if command -v dust >/dev/null 2>&1; then
    ok "Models ($MODELS): $(dust -d 0 -n 1 "$MODELS" 2>/dev/null | tail -n1 | awk '{print $1}')"
  else
    ok "Models ($MODELS): $(du -sh "$MODELS" 2>/dev/null | awk '{print $1}')"
  fi
fi
[ -d "$HF_CACHE" ] && ok "HF cache ($HF_CACHE): $(du -sh "$HF_CACHE" 2>/dev/null | awk '{print $1}')"

section "Memory"
phys_bytes=$(sysctl -n hw.memsize)
phys_mb=$((phys_bytes / 1024 / 1024))
ok "physical: ${phys_mb} MiB"
wired=$(sysctl -n iogpu.wired_limit_mb 2>/dev/null || echo 0)
if [ "$wired" -eq 0 ]; then
  warn "iogpu.wired_limit_mb: 0 (system default ~75% of physical); raise for 70B+ models"
else
  # Compare against the LaunchDaemon's exact target (run_once_after_035-iogpu-limit
  # rounds 95% of physical down to a 1024 MiB boundary) so the threshold here
  # stays in sync with what the daemon actually sets.
  target=$(( (phys_mb * 95 / 100) / 1024 * 1024 ))
  pct=$(awk -v w="$wired" -v p="$phys_mb" 'BEGIN { printf "%.1f", w * 100 / p }')
  if [ "$wired" -lt "$target" ]; then
    warn "iogpu.wired_limit_mb: ${wired} MiB (${pct}% of physical) — below daemon target ${target} MiB"
  else
    ok "iogpu.wired_limit_mb: ${wired} MiB (${pct}% of physical)"
  fi
fi

section "Bootstrap state"
# 010-install-homebrew
if command -v brew >/dev/null 2>&1; then
  ok "Homebrew: installed ($(brew --prefix))"
else
  miss "Homebrew: not installed (run_once_before_010)"
fi

# 020-brew-bundle
if [ -f "$HOME/.Brewfile" ]; then
  ok "Brewfile: present ($(grep -cE '^(brew|cask|tap|mas) "' "$HOME/.Brewfile") packages)"
else
  miss "\$HOME/.Brewfile: missing (run_once_after_020)"
fi

# 035-iogpu-limit (AI hosts only — only flag if missing on a host that should have it)
PLIST=/Library/LaunchDaemons/local.iogpu.wired-limit.plist
if [ -f "$PLIST" ]; then
  ok "iogpu LaunchDaemon: $PLIST present"
else
  warn "iogpu LaunchDaemon: not installed (run_once_after_035; AI-host gated)"
fi

# 040-macos-defaults — sample one of the writes for evidence the script ran
if [ "$(defaults read NSGlobalDomain AppleShowAllExtensions 2>/dev/null)" = "1" ]; then
  ok "macOS defaults: applied (Finder shows all extensions)"
else
  warn "macOS defaults: not applied (run_once_after_040)"
fi

# 045-time-machine — check excludes for paths we created
tm_excluded=0; tm_present=0
for p in "$HOME/Models" "$HOME/.cache/huggingface" "$HOME/.cache/uv" "$HOME/ai/playground/.venv"; do
  if [ -e "$p" ]; then
    tm_present=$((tm_present+1))
    tmutil isexcluded "$p" 2>/dev/null | grep -q '\[Excluded\]' && tm_excluded=$((tm_excluded+1))
  fi
done
if [ "$tm_present" -gt 0 ]; then
  if [ "$tm_excluded" = "$tm_present" ]; then
    ok "Time Machine excludes: ${tm_excluded}/${tm_present}"
  else
    warn "Time Machine excludes: ${tm_excluded}/${tm_present} (run_once_after_045)"
  fi
fi

# 050-sudo-touchid
if grep -qE '^auth[[:space:]]+sufficient[[:space:]]+pam_tid\.so' /etc/pam.d/sudo_local 2>/dev/null; then
  ok "sudo Touch ID: enabled"
else
  warn "sudo Touch ID: not configured (run_once_after_050)"
fi

# 060-chat-stack (AI-host gated; the whole section warn-skips cleanly if
# the script hasn't run on this machine, so non-AI hosts stay quiet).
CHAT_DIR="$HOME/ai/chat"
COMPOSE_FILE="$CHAT_DIR/docker-compose.yml"
if [ -f "$COMPOSE_FILE" ]; then
  section "Chat stack (060)"

  DOCKER=$(command -v docker || true)
  [ -z "$DOCKER" ] && [ -x /opt/homebrew/bin/docker ] && DOCKER=/opt/homebrew/bin/docker
  [ -z "$DOCKER" ] && [ -x /usr/local/bin/docker ] && DOCKER=/usr/local/bin/docker

  if [ -z "$DOCKER" ] || ! "$DOCKER" version >/dev/null 2>&1; then
    warn "docker daemon not reachable — open OrbStack to inspect chat stack"
  else
    # Parse via `jq` rather than docker's --format option, because the
    # Go-template syntax docker uses there collides with chezmoi's own
    # template processing of this file.
    for ctr in chat-pocket-id chat-open-webui; do
      raw=$("$DOCKER" inspect "$ctr" 2>/dev/null | jq -r '.[0] | (.State.Status) + "|" + (.State.Health.Status // "-")' 2>/dev/null || true)
      if [ -z "$raw" ] || [ "$raw" = "null|-" ]; then
        miss "$ctr: not created (re-run 060)"
        continue
      fi
      state=${raw%%|*}; health=${raw##*|}
      case "$state:$health" in
        running:healthy|running:-) ok "$ctr: $state${health:+ ($health)}";;
        running:*)                 warn "$ctr: $state ($health)";;
        *)                         miss "$ctr: $state${health:+ ($health)}";;
      esac
    done
  fi

  # .env: presence-only checks, never print values (OAUTH_CLIENT_SECRET +
  # ENCRYPTION_KEY are secrets that would otherwise end up in any
  # transcript / clipboard the user pipes mai-doctor through).
  ENV_FILE="$CHAT_DIR/.env"
  if [ ! -f "$ENV_FILE" ]; then
    miss "$ENV_FILE missing (re-run 060)"
  else
    if grep -qE '^ENCRYPTION_KEY=.+' "$ENV_FILE"; then
      ok "ENCRYPTION_KEY: set"
    else
      miss "ENCRYPTION_KEY: missing — Pocket-ID won't start without it"
    fi
    if grep -qE '^OAUTH_CLIENT_ID=.+' "$ENV_FILE"; then
      ok "OAUTH_CLIENT_ID: set"
    else
      warn "OAUTH_CLIENT_ID: empty — mint an OIDC client in Pocket-ID and paste it"
    fi
  fi

  # Tailnet IP drift: tailscale ip is stable per machine but re-auth can
  # change it. The Open WebUI container's /etc/hosts entry in compose
  # would then point at a dead IP, breaking server-side OIDC. Compare
  # what compose has against what tailscaled reports now.
  if command -v tailscale >/dev/null 2>&1; then
    current_ip=$(tailscale ip -4 2>/dev/null | head -1)
    compose_ip=$(grep -oE 'ts\.net:[0-9]+(\.[0-9]+){3}' "$COMPOSE_FILE" | head -1 | cut -d: -f2)
    if [ -n "$current_ip" ] && [ -n "$compose_ip" ]; then
      if [ "$current_ip" = "$compose_ip" ]; then
        ok "tailnet IP in compose: $compose_ip"
      else
        warn "tailnet IP drift: compose=$compose_ip vs current=$current_ip (re-run 060)"
      fi
    fi

    # tailscale serve: check by the upstream target since `:443` doesn't
    # appear in `serve status` output (it's the default port).
    serve=$(tailscale serve status 2>/dev/null || true)
    if printf '%s' "$serve" | grep -q '127\.0\.0\.1:3000'; then
      ok "tailscale serve → Open WebUI (port 3000)"
    else
      warn "tailscale serve → 127.0.0.1:3000 not configured (re-run 060)"
    fi
    if printf '%s' "$serve" | grep -q '127\.0\.0\.1:1411'; then
      ok "tailscale serve → Pocket-ID (port 1411)"
    else
      warn "tailscale serve → 127.0.0.1:1411 not configured (re-run 060)"
    fi
  fi
fi

if [ "$issues" -eq 0 ]; then
  printf "\n\033[32mOK\033[0m\n"
else
  printf "\nIssues found: %d\n" "$issues"
fi
exit 0
{{ end -}}
