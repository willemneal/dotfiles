{{- if eq .chezmoi.os "darwin" -}}
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE SHARE_HISTORY INC_APPEND_HISTORY

# EDITOR=nvim contains "vi", so zsh auto-selects viins. Force emacs keymap
# so ^A/^E/^U/^K/^W behave normally.
bindkey -e

autoload -Uz compinit && compinit

command -v starship >/dev/null && eval "$(starship init zsh)"
command -v zoxide   >/dev/null && eval "$(zoxide init zsh)"
command -v direnv   >/dev/null && eval "$(direnv hook zsh)"
command -v mise     >/dev/null && eval "$(mise activate zsh)"
# fzf is sourced before atuin so atuin's Ctrl+R binding wins.
[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ] && . /opt/homebrew/opt/fzf/shell/key-bindings.zsh
[ -f /opt/homebrew/opt/fzf/shell/completion.zsh   ] && . /opt/homebrew/opt/fzf/shell/completion.zsh

command -v atuin    >/dev/null && eval "$(atuin init zsh --disable-up-arrow)"

# Source order matters: autosuggestions before syntax-highlighting.
[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && \
  . /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[ -f /opt/homebrew/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh ] && \
  . /opt/homebrew/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh

alias ls='eza'
alias ll='eza -lah --git'
alias lt='eza --tree --level=2'
alias cat='bat --paging=never'
alias vim='nvim'
alias g='git'
alias du='dust'
alias top='btm'

alias hfd='hf download'
alias play='cd $HOME/ai/playground && uv run python'
alias jlab='cd $HOME/ai/playground && uv run jupyter lab'

# cargo-binstall shorthand (cargo-binstall is in the Brewfile).
alias cbi='cargo binstall'
alias cbif='cargo binstall --force -y'

[ -f "$HOME/.zshrc.local" ] && . "$HOME/.zshrc.local"
{{ end -}}
